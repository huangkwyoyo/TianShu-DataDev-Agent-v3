# Python 编译缓存
__pycache__/
*.py[cod]
*.egg-info/

# pytest 缓存
.pytest_cache/
.pytest_tmp/
.coverage

# 虚拟环境
.venv/
venv/

# IDE
.vscode/
.idea/

# 环境变量
.env

# Node 依赖缓存（前端）
node_modules/

# 运行时产物
generated/review_packages/
frontend/generated/

# 项目级缓存——快照、临时数据
.tianshu_cache/

# Superpowers 内部跟踪文件
.superpowers/

# CodeGraph 索引
.codegraph/
frontend/dist/

# Playwright E2E 测试运行时产物
frontend/test-results/

# 真实 LLM 回归验证报告输出
llm_reports/

# dev-reload 启动日志——忽略目录下所有内容，但保留 .gitkeep
logs/dev/*
!logs/dev/.gitkeep

# 全流程运行监控系统日志
logs/monitor/
logs/monitor-text/
